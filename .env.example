# ─── Intelligence Artificielle ────────────────────────────────────────────────
# Clé API Groq (modèle llama-3.3-70b-versatile) — requis pour la génération de devis
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Base de données ──────────────────────────────────────────────────────────
# PostgreSQL via Prisma — requis pour PrismaQuoteRepository
DATABASE_URL=postgresql://user:password@localhost:5432/maestro

# ─── Environnement ────────────────────────────────────────────────────────────
NODE_ENV=development
